# ============================================================================
# Namaa backend environment — copy to backend/.env and fill in real values.
# backend/.env is loaded by settings.py via python-dotenv; real shell
# environment variables always take precedence over this file.
# Never commit backend/.env (it is gitignored).
# ============================================================================

# --- Django core ------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
# Comma-separated, e.g. api.namaa.sa,localhost
DJANGO_ALLOWED_HOSTS=

# --- JWT auth (djangorestframework-simplejwt) -------------------------------
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
# Optional: separate signing key; falls back to DJANGO_SECRET_KEY when empty.
JWT_SIGNING_KEY=

# --- Two-factor authentication ----------------------------------------------
# Issuer label shown in authenticator apps.
TWO_FACTOR_ISSUER=Namaa

# --- Moyasar (payments, docs.moyasar.com) -----------------------------------
MOYASAR_API_BASE_URL=https://api.moyasar.com/v1
# Secret key from the Moyasar dashboard (sk_test_... / sk_live_...).
MOYASAR_SECRET_KEY=
# Shared secret_token configured on the Moyasar webhook endpoint.
MOYASAR_WEBHOOK_SECRET=

# --- Taqnyat (SMS, taqnyat.sa) ----------------------------------------------
TAQNYAT_API_BASE_URL=https://api.taqnyat.sa
# Bearer token from the Taqnyat dashboard.
TAQNYAT_BEARER_TOKEN=
# Pre-approved sender name on the Taqnyat account.
TAQNYAT_SMS_SENDER=

# --- Email: Django framework mail over SES SMTP -----------------------------
# Dev default is the console backend; set the SMTP backend in production:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=
EMAIL_HOST=email-smtp.me-south-1.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
# SES *SMTP credentials* (not the IAM access keys below).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=Namaa <no-reply@namaa.sa>
SERVER_EMAIL=

# --- Email: SES v2 API (customer-facing dispatches & campaigns) -------------
AWS_SES_REGION=me-south-1
# IAM keys; may stay blank on AWS runtimes resolving an instance role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Configuration set whose SNS event destination posts to /api/v1/webhooks/ses/
AWS_SES_CONFIGURATION_SET=
# Exact SNS topic ARN carrying SES events — webhook fails closed when blank.
AWS_SES_SNS_TOPIC_ARN=
SES_FROM_EMAIL=no-reply@namaa.sa

# --- ZATCA Fatoora (Phase-2 e-invoicing) ------------------------------------
# sandbox = developer portal, simulation = PRE production drill, production = live.
ZATCA_ENVIRONMENT=sandbox
# Optional explicit override; otherwise derived from ZATCA_ENVIRONMENT.
ZATCA_API_BASE_URL=
# Fernet key encrypting device private keys and CSID secrets at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ZATCA_KEY_ENCRYPTION_KEY=

# --- API rate limits (active when DJANGO_DEBUG=false) ------------------------
API_THROTTLE_ANON=60/min
API_THROTTLE_USER=600/min

# --- Celery / Redis ----------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
# Falls back to CELERY_BROKER_URL when empty.
CELERY_RESULT_BACKEND=
# true only in tests/dev without a worker.
CELERY_TASK_ALWAYS_EAGER=false
